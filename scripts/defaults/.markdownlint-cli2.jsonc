{
    "globs": [
        "**/*.md",
        "!.git/**",
        "!build/**"
    ],

    "showFound": true,
    "noBanner": true,
    "noProgress": false,

    "config": {
        "default": true,
        "MD013": false,     // Allow for 80+ line-length
        "MD007": false      // Allow for four-space ident of unordered lists.
    }

}
